@model IEnumerable<WebProjectTurist.Models.Korisnik>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Pregled korisnika";
}

<h2>Pregled korisnika</h2>

<form method="get" class="mb-3">
    <label>Pretraga (ime/prezime): </label>
    <input type="text" name="pretraga" value="@Request["pretraga"]" class="form-control w-25 d-inline" />

    <label class="ms-3">Uloga:</label>
    <select name="uloga" class="form-select w-auto d-inline">
        <option value="">Sve</option>
        <option>Administrator</option>
        <option>Menadzer</option>
        <option>Turista</option>
    </select>

    <input type="submit" value="Filtriraj" class="btn btn-primary ms-3" />
    <a href="/Admin/NoviMenadzer" class="btn btn-success ms-2">+ Novi menadžer</a>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Korisničko ime</th>
            <th>Ime</th>
            <th>Prezime</th>
            <th>Email</th>
            <th>Uloga</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.KorisnickoIme</td>
                <td>@k.Ime</td>
                <td>@k.Prezime</td>
                <td>@k.Email</td>
                <td>@k.Uloga</td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">Nema pronađenih korisnika.</p>
}
