@model WebProjectTurist.Models.Korisnik
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Novi menadžer";
}

<h2>Registracija novog menadžera</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form method="post" class="mt-3">
    <div class="mb-3">
        <label>Korisničko ime:</label>
        <input type="text" name="KorisnickoIme" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Lozinka:</label>
        <input type="password" name="Lozinka" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Ime:</label>
        <input type="text" name="Ime" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Prezime:</label>
        <input type="text" name="Prezime" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Pol:</label>
        <select name="Pol" class="form-select">
            <option>Muško</option>
            <option>Žensko</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Email:</label>
        <input type="email" name="Email" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Datum rođenja:</label>
        <input type="text" name="DatumRodjenja" placeholder="dd/MM/yyyy" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Sačuvaj menadžera</button>
    <a href="/Admin/Korisnici" class="btn btn-secondary">Nazad</a>
</form>
