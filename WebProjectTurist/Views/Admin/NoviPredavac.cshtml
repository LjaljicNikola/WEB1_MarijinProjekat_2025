@{
    ViewBag.Title = "Novi predavač";
}

<h2>Kreiranje novog predavača</h2>

@if (!string.IsNullOrEmpty(ViewBag.Error))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@using (Html.BeginForm("NoviPredavac", "Admin", FormMethod.Post))
{
    <div class="form-group">
        <label>Korisničko ime: *</label>
        <input type="text" name="korisnickoIme" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Lozinka: *</label>
        <input type="password" name="lozinka" class="form-control" required />
    </div>
    <div class="form-group">
        <label>JMBG (13 cifara): *</label>
        <input type="text" name="jmbg" class="form-control" maxlength="13" pattern="\d{13}" required />
    </div>
    <div class="form-group">
        <label>Ime: *</label>
        <input type="text" name="ime" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Prezime: *</label>
        <input type="text" name="prezime" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Datum rođenja (dd/MM/yyyy): *</label>
        <input type="text" name="datumRodjenja" class="form-control" placeholder="01/01/1985" required />
    </div>
    <div class="form-group">
        <label>Email: *</label>
        <input type="email" name="email" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Oblast ekspertize: *</label>
        <select name="oblastEkspertize" class="form-control" required>
            <option value="">-- Izaberite --</option>
            @foreach (var o in Enum.GetValues(typeof(WebProjectTurist.Models.OblastEkspertize)))
            {
                <option value="@o">@o</option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-success">Kreiraj predavača</button>
    <a href="@Url.Action("Predavaci", "Admin")" class="btn btn-default">Odustani</a>
}
