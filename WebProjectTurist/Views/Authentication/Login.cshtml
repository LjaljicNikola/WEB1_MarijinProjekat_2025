@{
    ViewBag.Title = "Prijava na sistem";
}

<h2>Prijava na sistem</h2>

@if (!string.IsNullOrEmpty(ViewBag.Message))
{
    <div class="alert alert-danger">@ViewBag.Message</div>
}

@using (Html.BeginForm("Login", "Authentication", FormMethod.Post))
{
    <div class="form-group">
        <label>Korisničko ime:</label>
        <input type="text" name="korisnickoIme" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Lozinka:</label>
        <input type="password" name="lozinka" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-primary">Prijavi se</button>
    <a href="@Url.Action("Register", "Authentication")" class="btn btn-link">Registracija</a>
}
