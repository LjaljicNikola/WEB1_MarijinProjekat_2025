@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Prijava";
}

<h2>Prijava na sistem</h2>

@if (ViewBag.Message != null)
{
    <div style="color:red">@ViewBag.Message</div>
}

<form action="~/Authentication/Login" method="post">
    <table>
        <tr>
            <td>Korisnicko ime:</td>
            <td><input type="text" name="korisnickoIme" required /></td>
        </tr>
        <tr>
            <td>Lozinka:</td>
            <td><input type="password" name="lozinka" required /></td>
        </tr>
        <tr>
            <td colspan="2" style="text-align:center;">
                <input type="submit" value="Prijavi se" />
            </td>
        </tr>
    </table>
</form>

<p>Nemas nalog? <a href="~/Authentication/Register">Registruj se</a></p>
