@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Registracija";
}

<h2>Registracija korisnika</h2>

@if (ViewBag.Message != null)
{
    <div style="color:red">@ViewBag.Message</div>
}

<form action="~/Authentication/Register" method="post">
    <table>
        <tr>
            <td>Korisnicko ime:</td>
            <td><input type="text" name="korisnickoIme" required /></td>
        </tr>
        <tr>
            <td>Lozinka:</td>
            <td><input type="password" name="lozinka" required /></td>
        </tr>
        <tr>
            <td>Ime:</td>
            <td><input type="text" name="ime" required /></td>
        </tr>
        <tr>
            <td>Prezime:</td>
            <td><input type="text" name="prezime" required /></td>
        </tr>
        <tr>
            <td>Pol:</td>
            <td>
                <select name="pol" required>
                    <option value="M">Muski</option>
                    <option value="Z">Zenski</option>
                </select>
            </td>
        </tr>
        <tr>
            <td>Email:</td>
            <td><input type="email" name="email" required /></td>
        </tr>
        <tr>
            <td>Datum rodjenja:</td>
            <td><input type="date" name="datumRodjenja" required /></td>
        </tr>
        <tr>
            <td colspan="2" style="text-align:center;">
                <input type="submit" value="Registruj se" />
            </td>
        </tr>
    </table>
</form>

<p>Već imaš nalog? <a href="~/Authentication/Login">Prijavi se</a></p>
