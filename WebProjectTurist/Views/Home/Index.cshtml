@model List<WebProjectTurist.Models.Radionica>
@{
    ViewBag.Title = "Radionice";
    var uloga = Session["uloga"] as string;
}

<h2>Dostupne radionice</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model.Count == 0)
{
    <p>Trenutno nema dostupnih radionica.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Naziv</th>
                <th>Kategorija</th>
                <th>Datum i vreme početka</th>
                <th>Trajanje (min)</th>
                <th>Mesto</th>
                <th>Slobodna mesta</th>
                <th>Status</th>
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Naziv</td>
                    <td>@r.Kategorija</td>
                    <td>@r.DatumVremepocetka</td>
                    <td>@r.Trajanje</td>
                    <td>@r.MestoOdrzavanja</td>
                    <td>@r.BrojSlobodnihMesta / @r.MaksimalanBrojUcesnika</td>
                    <td>@r.Status</td>
                    <td>
                        <a href="@Url.Action("Detalji", "Home", new { id = r.Id })" class="btn btn-sm btn-info">Detalji</a>
                        @if (uloga == "Ucesnik")
                        {
                            using (Html.BeginForm("PrijaviSe", "Ucesnik", FormMethod.Post, new { style = "display:inline" }))
                            {
                                <input type="hidden" name="radionicaId" value="@r.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Prijavi se</button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
