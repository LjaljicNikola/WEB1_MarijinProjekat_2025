﻿@model List<WebProjectTurist.Models.Aranzman>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Upravljanje aranžmanima";
    var moji = ViewBag.MojiAranzmani as List<WebProjectTurist.Models.Aranzman>;
}

<div class="container mt-4">
    <h2>🧳 Upravljanje aranžmanima</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info mt-2">@TempData["Message"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
        <form class="form-inline" method="get" action="/Menadzer/Aranzmani">
            <input type="text" name="pretraga" placeholder="Pretraga po nazivu ili lokaciji"
                   class="form-control mr-2" value="@Request["pretraga"]" />
            <select name="sort" class="form-control mr-2">
                <option value="">Sortiraj po...</option>
                <option value="nazivAsc">Naziv (A–Z)</option>
                <option value="nazivDesc">Naziv (Z–A)</option>
            </select>
            <button type="submit" class="btn btn-primary">🔍 Pretraži</button>
        </form>

        <a href="/Menadzer/NoviAranzman" class="btn btn-success">➕ Novi aranžman</a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <p class="text-muted">Nema dostupnih aranžmana.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Naziv</th>
                    <th>Tip</th>
                    <th>Prevoz</th>
                    <th>Lokacija</th>
                    <th>Datumi</th>
                    <th>Maks. putnika</th>
                    <th>Opis</th>
                    <th>Opcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    bool moj = moji != null && moji.Any(x => x.Naziv == a.Naziv);

                    <tr class="@(moj ? "table-info" : "")">
                        <td>@a.Naziv</td>
                        <td>@a.TipAranzmana</td>
                        <td>@a.TipPrevoza</td>
                        <td>@a.Lokacija</td>
                        <td>@a.DatumPocetka - @a.DatumZavrsetka</td>
                        <td>@a.MaksimalanBrojPutnika</td>
                        <td>@(a.Opis?.Length > 50 ? a.Opis.Substring(0, 50) + "..." : a.Opis)</td>
                        <td>
                            @if (moj)
                            {
                                <div class="d-flex flex-column gap-1">
                                    <div>
                                        <a href="/Menadzer/IzmeniAranzman?naziv=@a.Naziv" class="btn btn-warning btn-sm">✏ Izmeni</a>
                                        <form action="/Menadzer/ObrisiAranzman" method="post" style="display:inline;">
                                            <input type="hidden" name="naziv" value="@a.Naziv" />
                                            <button type="submit" class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Da li ste sigurni da želite da obrišete aranžman?');">
                                                🗑 Obriši
                                            </button>
                                        </form>
                                    </div>
                                    <div>
                                        <a href="/Menadzer/Smestaji?nazivAranzmana=@a.Naziv" class="btn btn-info btn-sm">🏨 Smeštaji</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Tuđi aranžman</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>