﻿@model WebProjectTurist.Models.Aranzman
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Izmena aranžmana";
}

<div class="container mt-4">
    <h2>✏ Izmena aranžmana – @Model.Naziv</h2>

    <form method="post" action="/Menadzer/SacuvajIzmenjenAranzman" enctype="multipart/form-data" class="mt-3">
        <input type="hidden" name="Naziv" value="@Model.Naziv" />

        <div class="form-group mb-3">
            <label>Tip aranžmana:</label>
            <select name="TipAranzmana" class="form-control" required>
                @foreach (var tip in Enum.GetValues(typeof(WebProjectTurist.Models.AranzmanTip)))
                {
                    <option value="@tip" @(tip.Equals(Model.TipAranzmana) ? "selected" : "")>@tip</option>
                }
            </select>
        </div>

        <div class="form-group mb-3">
            <label>Tip prevoza:</label>
            <select name="TipPrevoza" class="form-control" required>
                @foreach (var t in Enum.GetValues(typeof(WebProjectTurist.Models.TransportTip)))
                {
                    <option value="@t" @(t.Equals(Model.TipPrevoza) ? "selected" : "")>@t</option>
                }
            </select>
        </div>

        <div class="form-group mb-3">
            <label>Lokacija:</label>
            <select name="Lokacija" class="form-control" required>
                @foreach (var l in Enum.GetValues(typeof(WebProjectTurist.Models.LokacijAranzmana)))
                {
                    <option value="@l" @(l.Equals(Model.Lokacija) ? "selected" : "")>@l</option>
                }
            </select>
        </div>

        <div class="form-group mb-3"> <label>Datum početka:</label> 
        <input type="date" name="DatumPocetka" value="@Convert.ToDateTime(Model.DatumPocetka).ToString("yyyy-MM-dd")" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>Datum završetka:</label>
            <input type="date" name="DatumZavrsetka" value="@Convert.ToDateTime(Model.DatumZavrsetka).ToString("yyyy-MM-dd")" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>Maksimalan broj putnika:</label>
            <input type="number" name="MaksimalanBrojPutnika" value="@Model.MaksimalanBrojPutnika" class="form-control" min="1" required />
        </div>

        <div class="form-group mb-3">
            <label>Opis:</label>
            <textarea name="Opis" class="form-control" rows="3">@Model.Opis</textarea>
        </div>

        <div class="form-group mb-3">
            <label>Program putovanja:</label>
            <textarea name="ProgramPutovanja" class="form-control" rows="4">@Model.ProgramPutovanja</textarea>
        </div>

        <div class="form-group mb-3">
            <label>Trenutni poster:</label>
            <div class="mb-2">
                <img id="posterPreview"
                     src="@Model.Poster"
                     alt="Poster"
                     style="max-width: 200px; max-height: 150px;"
                     class="img-thumbnail" />
            </div>

            <label>Novi poster (izaberi sliku):</label>
            <input type="file" name="PosterFile" class="form-control" accept="image/*" onchange="previewPoster(this)" />
        </div>

        <script>
            function previewPoster(input) {
                if (input.files && input.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        document.getElementById('posterPreview').src = e.target.result;
                    }
                    reader.readAsDataURL(input.files[0]);
                }
            }
        </script>

        <button type="submit" class="btn btn-primary">💾 Sačuvaj izmene</button>
        <a href="/Menadzer/Aranzmani" class="btn btn-secondary">Nazad</a>
    </form>
</div>