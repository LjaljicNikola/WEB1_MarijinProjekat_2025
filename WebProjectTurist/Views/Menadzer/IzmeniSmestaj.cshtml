@model WebProjectTurist.Models.Smestaj
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Izmeni smeštaj";
}

<h2 class="text-center">Izmena smeštaja</h2>

@using (Html.BeginForm("SacuvajIzmeneSmestaja", "Menadzer", FormMethod.Post))
{
    <div class="form-horizontal" style="max-width: 600px; margin: 0 auto;">
        <hr />

        <div class="form-group">
            @Html.LabelFor(m => m.Naziv, "Naziv smeštaja", new { @class = "control-label col-md-4" })
            <div class="col-md-8">
                @Html.TextBoxFor(m => m.Naziv, new { @class = "form-control", @readonly = "readonly" })
            </div>
        </div>

        <!-- Tip smeštaja -->
        <div class="form-group">
            @Html.LabelFor(m => m.Tip, "Tip smeštaja", new { @class = "control-label col-md-4" })
            <div class="col-md-8">
                @Html.DropDownListFor(m => m.Tip,
                    new SelectList(Enum.GetValues(typeof(WebProjectTurist.Models.SmestajTip))),
                    new { @class = "form-control", id = "tipSelect" })
            </div>
        </div>

        <!-- Broj zvezdica -->
        <div class="form-group">
            @Html.LabelFor(m => m.BrojZvezdica, "Broj zvezdica", new { @class = "control-label col-md-4" })
            <div class="col-md-8">
                @Html.TextBoxFor(m => m.BrojZvezdica, new { @class = "form-control", type = "number", min = "1", max = "5", id = "zvezdiceInput" })
            </div>
        </div>

        <hr />

        <!-- Dodatne opcije -->
        <div class="form-group">
            <div class="col-md-offset-4 col-md-8">
                <div class="checkbox"><label>@Html.CheckBoxFor(m => m.Bazen) Bazen</label></div>
                <div class="checkbox"><label>@Html.CheckBoxFor(m => m.Spa) Spa centar</label></div>
                <div class="checkbox"><label>@Html.CheckBoxFor(m => m.Invaliditet) Pristup osobama sa invaliditetom</label></div>
                <div class="checkbox"><label>@Html.CheckBoxFor(m => m.Wifi) Besplatan Wi-Fi</label></div>
            </div>
        </div>

        <hr />

        <!-- Dugmad -->
        <div class="form-group text-center">
            <input type="submit" value="Sačuvaj izmene" class="btn btn-primary" style="width: 200px;" />
            <a href="@Url.Action("Smestaji", "Menadzer", new { nazivAranzmana = ViewBag.NazivAranzmana })"
               class="btn btn-secondary" style="width: 200px; margin-left: 10px;">
                Nazad
            </a>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tipSelect = document.getElementById("tipSelect");
        const zvezdiceInput = document.getElementById("zvezdiceInput");

        function toggleZvezdice() {
            const tip = tipSelect.value.toLowerCase();
            if (tip === "hotel") {
                zvezdiceInput.disabled = false;
            } else {
                zvezdiceInput.value = "";
                zvezdiceInput.disabled = true;
            }
        }

        tipSelect.addEventListener("change", toggleZvezdice);
        toggleZvezdice();
    });
</script>
