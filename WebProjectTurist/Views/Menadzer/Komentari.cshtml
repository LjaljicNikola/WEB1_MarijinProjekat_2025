@model List<WebProjectTurist.Models.Komentar>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Komentari mojih aranžmana";
}

<div class="container mt-4">
    <h2>💬 Komentari mojih aranžmana</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info mt-2">@TempData["Message"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
        <a href="/Menadzer/Aranzmani" class="btn btn-secondary">⬅ Nazad na aranžmane</a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <p class="text-muted">Nema komentara za vaše aranžmane.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Turista</th>
                    <th>Smeštaj</th>
                    <th>Ocena</th>
                    <th>Komentar</th>
                    <th>Status</th>
                    <th>Akcije</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var k = Model[i];
                    <tr>
                        <td>@k.Turista.KorisnickoIme</td>
                        <td>@k.SmestajKomentar.Naziv</td>
                        <td>@k.Ocena / 5</td>
                        <td>@k.Tekst</td>
                        <td>
                            @if (k.Odobren)
                            {
                                <span class="badge bg-success">Odobren</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Na čekanju / Odbijen</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <form action="/Menadzer/OdobriKomentar" method="post">
                                    <input type="hidden" name="index" value="@i" />
                                    <button type="submit" class="btn btn-success btn-sm">✅ Odobri</button>
                                </form>

                                <form action="/Menadzer/OdbijKomentar" method="post">
                                    <input type="hidden" name="index" value="@i" />
                                    <button type="submit" class="btn btn-danger btn-sm">❌ Odbij</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
