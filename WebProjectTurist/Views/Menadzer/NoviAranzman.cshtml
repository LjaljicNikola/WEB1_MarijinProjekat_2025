@model WebProjectTurist.Models.Aranzman
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Kreiraj novi aranzman";
}

<div class="container mt-4">
    <h2>➕ Kreiraj novi aranzman</h2>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-danger mt-3">@ViewBag.Message</div>
    }

<form method="post" action="/Menadzer/SacuvajNoviAranzman" enctype="multipart/form-data" class="mt-3">
    <div class="form-group mb-3">
        <label>Naziv aranzmana:</label>
        <input type="text" name="Naziv" class="form-control" required />
    </div>

    <div class="form-group mb-3">
        <label>Tip aranžmana:</label>
        <select name="TipAranzmana" class="form-control" required>
            @foreach (var tip in Enum.GetValues(typeof(WebProjectTurist.Models.AranzmanTip)))
            {
                <option value="@tip">@tip</option>
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Tip prevoza:</label>
        <select name="TipPrevoza" class="form-control" required>
            @foreach (var t in Enum.GetValues(typeof(WebProjectTurist.Models.TransportTip)))
            {
                <option value="@t">@t</option>
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Lokacija:</label>
        <select name="Lokacija" class="form-control" required>
            @foreach (var l in Enum.GetValues(typeof(WebProjectTurist.Models.LokacijAranzmana)))
            {
                <option value="@l">@l</option>
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Datum pocetka:</label>
        <input type="date" name="DatumPocetka" class="form-control" placeholder="dd/MM/yyyy" required />
    </div>

    <div class="form-group mb-3">
        <label>Datum zavrsetka:</label>
        <input type="date" name="DatumZavrsetka" class="form-control" placeholder="dd/MM/yyyy" required />
    </div>

    <div class="form-group mb-3">
        <label>Maksimalan broj putnika:</label>
        <input type="number" name="MaksimalanBrojPutnika" class="form-control" min="1" required />
    </div>

    <div class="form-group mb-3">
        <label>Opis aranzmana:</label>
        <textarea name="Opis" class="form-control" rows="3"></textarea>
    </div>

    <div class="form-group mb-3">
        <label>Program putovanja:</label>
        <textarea name="ProgramPutovanja" class="form-control" rows="4"></textarea>
    </div>

    <div class="form-group mb-3">
        <label>Poster (izaberi sliku):</label>
        <input type="file" name="PosterFile" class="form-control" accept="image/*" required />
    </div>


    <button type="submit" class="btn btn-success">💾 Sacuvaj</button>
    <a href="/Menadzer/Aranzmani" class="btn btn-secondary">Nazad</a>
</form>
</div>
