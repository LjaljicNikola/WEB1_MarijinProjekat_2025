@model WebProjectTurist.Models.Smestaj
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Dodaj novi smeštaj";
    var nazivAranzmana = ViewBag.NazivAranzmana;
}

<div class="container mt-4">
    <h2>➕ Novi smeštaj za aranžman: <b>@nazivAranzmana</b></h2>

    <form method="post" action="/Menadzer/SacuvajNoviSmestaj">
        <input type="hidden" name="nazivAranzmana" value="@nazivAranzmana" />

        <div class="form-group mb-3">
            <label>Naziv smeštaja:</label>
            <input type="text" name="Naziv" class="form-control" required />
        </div>

        <div class="form-group mb-3">
            <label>Tip smeštaja:</label>
            <select name="Tip" class="form-control" id="tipSelect" required>
                @foreach (var tip in Enum.GetValues(typeof(WebProjectTurist.Models.SmestajTip)))
                {
                    <option value="@tip">@tip</option>
                }
            </select>
        </div>

        <div class="form-group mb-3">
            <label>Broj zvezdica:</label>
            <input type="number" id="zvezdiceInput" name="BrojZvezdica" min="1" max="5" class="form-control" />
        </div>

        <div class="form-check mb-2">
            <input type="checkbox" class="form-check-input" name="Bazen" value="true" />
            <label class="form-check-label">Bazen</label>
        </div>

        <div class="form-check mb-2">
            <input type="checkbox" class="form-check-input" name="Spa" value="true" />
            <label class="form-check-label">Spa centar</label>
        </div>

        <div class="form-check mb-2">
            <input type="checkbox" class="form-check-input" name="Invaliditet" value="true" />
            <label class="form-check-label">Prilagođen osobama sa invaliditetom</label>
        </div>

        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" name="Wifi" value="true" />
            <label class="form-check-label">Wi-Fi</label>
        </div>

        <button type="submit" class="btn btn-success">💾 Sačuvaj</button>
        <a href="/Menadzer/Smestaji?nazivAranzmana=@nazivAranzmana" class="btn btn-secondary">Nazad</a>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tipSelect = document.getElementById("tipSelect");
        const zvezdiceInput = document.getElementById("zvezdiceInput");

        function toggleZvezdice() {
            const tip = tipSelect.value.toLowerCase();
            if (tip === "hotel") {
                zvezdiceInput.disabled = false;
            } else {
                zvezdiceInput.value = "";
                zvezdiceInput.disabled = true;
            }
        }

        tipSelect.addEventListener("change", toggleZvezdice);
        toggleZvezdice();
    });
</script>
