@model List<WebProjectTurist.Models.Rezervacija>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Rezervacije mojih aranžmana";
}

<div class="container mt-4">
    <h2>📋 Rezervacije mojih aranžmana</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info mt-2">@TempData["Message"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
        <a href="/Menadzer/Aranzmani" class="btn btn-secondary">⬅ Nazad na aranžmane</a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <p class="text-muted">Nema rezervacija za vaše aranžmane.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>Turista</th>
                    <th>Aranžman</th>
                    <th>Datum početka</th>
                    <th>Datum završetka</th>
                    <th>Status</th>
                    <th>Cena</th>
                    <th>Detalji</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.TuristaKorisnickoIme</td>
                        <td>@r.AranzmanRezervacije.Naziv</td>
                        <td>@r.AranzmanRezervacije.DatumPocetka</td>
                        <td>@r.AranzmanRezervacije.DatumZavrsetka</td>
                        <td>@r.Status</td>
                        <td>@r.Jedinica.Cena €</td>
                        <td>
                            @Html.ActionLink("Detalji", "DetaljiRezervacije", new { id = r.Id }, new { @class = "btn btn-primary btn-sm" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
