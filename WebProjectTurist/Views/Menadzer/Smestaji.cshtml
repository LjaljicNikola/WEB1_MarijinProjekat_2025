@model List<WebProjectTurist.Models.Smestaj>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Smeštaji";
    var nazivAranzmana = Request["nazivAranzmana"];
}

<div class="container mt-4">
    <h2>🏨 Smeštaji za aranžman: <b>@nazivAranzmana</b></h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info mt-2">@TempData["Message"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
        <a href="/Menadzer/NoviSmestaj?nazivAranzmana=@nazivAranzmana" class="btn btn-success">➕ Dodaj novi smeštaj</a>
        <a href="/Menadzer/Aranzmani" class="btn btn-secondary">⬅ Nazad na aranžmane</a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <p class="text-muted">Nema smeštaja za ovaj aranžman.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Naziv</th>
                    <th>Tip</th>
                    <th>Broj zvezdica</th>
                    <th>Bazen</th>
                    <th>Spa</th>
                    <th>Prilagođen invalidima</th>
                    <th>Wi-Fi</th>
                    <th>Broj jedinica</th>
                    <th>Opcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Naziv</td>
                        <td>@s.Tip</td>
                        <td>@s.BrojZvezdica</td>
                        <td>@(s.Bazen ? "Da" : "Ne")</td>
                        <td>@(s.Spa ? "Da" : "Ne")</td>
                        <td>@(s.Invaliditet ? "Da" : "Ne")</td>
                        <td>@(s.Wifi ? "Da" : "Ne")</td>
                        <td>@s.SmestajneJedinice.Count</td>
                        <td>
                            <a href="/Menadzer/SmestajneJedinice?nazivSmestaja=@s.Naziv&nazivAranzmana=@nazivAranzmana" class="btn btn-info btn-sm">🏠 Jedinice</a>
                            
                            <form action="/Menadzer/ObrisiSmestaj" method="post" style="display:inline;">
                                <input type="hidden" name="nazivSmestaja" value="@s.Naziv" />
                                <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Da li ste sigurni da želite da obrišete smeštaj?');">
                                    🗑 Obriši
                                </button>
                                <a href="@Url.Action("IzmeniSmestaj", "Menadzer", new { nazivSmestaja = s.Naziv, nazivAranzmana = nazivAranzmana })"
                                   class="btn btn-warning btn-sm">✏ Izmeni</a>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
