@model WebProjectTurist.Models.Korisnik
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Moj profil";
}

<h2>Moj profil</h2>

<p><strong>Korisničko ime:</strong> @Model.KorisnickoIme</p>
<p><strong>Ime:</strong> @Model.Ime</p>
<p><strong>Prezime:</strong> @Model.Prezime</p>
<p><strong>Pol:</strong> @Model.Pol</p>
<p><strong>Email:</strong> @Model.Email</p>
<p><strong>Datum rođenja:</strong> @Model.DatumRodjenja</p>
<p><strong>Uloga:</strong> @Model.Uloga</p>

<a href="/Profile/EditProfile" class="btn btn-secondary">Izmeni profil</a>
