@model WebProjectTurist.Models.Rezervacija
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Ostavi komentar";
}

<h2>Komentar za smeštaj: @Model.AranzmanRezervacije.Naziv</h2>

<form action="/Turista/OstaviKomentar" method="post" class="p-3" style="border: 1px solid #ccc; border-radius: 8px; width: 400px;">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="form-group mb-2">
        <label for="tekst">Vaš komentar:</label>
        <textarea name="tekst" class="form-control" required rows="4" placeholder="Unesite komentar..."></textarea>
    </div>

    <div class="form-group mb-3">
        <label for="ocena">Ocena (1–5):</label>
        <input type="number" name="ocena" min="1" max="5" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Pošalji komentar</button>
    <a href="/Turista/Rezervacije" class="btn btn-secondary">Nazad</a>
</form>
