@model List<WebProjectTurist.Models.Rezervacija>
@using WebProjectTurist.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Moje rezervacije";
    var message = TempData["Message"] as string;
}

<h2>Moje rezervacije</h2>

<div style="margin-bottom:15px;">
    <a href="/Home/Index" class="btn btn-success">➕ Nova rezervacija</a>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info">@message</div>
}


<form method="get" action="/Turista/Rezervacije" class="form-inline" style="margin-bottom:15px;">
    <input type="text" name="pretragaId" placeholder="ID rezervacije" class="form-control" />
    <input type="text" name="nazivAranzmana" placeholder="Naziv aranžmana" class="form-control" />
    <select name="status" class="form-control">
        <option value="">-- Status --</option>
        <option value="Aktivna">Aktivna</option>
        <option value="Otkazana">Otkazana</option>
    </select>
    <select name="sort" class="form-control">
        <option value="">-- Sortiranje --</option>
        <option value="nazivAsc">Naziv ↑</option>
        <option value="nazivDesc">Naziv ↓</option>
    </select>
    <input type="submit" value="Pretraži" class="btn btn-primary" />
</form>

@if (Model == null || !Model.Any())
{
    <p>Nema pronađenih rezervacija.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID rezervacije</th>
                <th>Naziv aranžmana</th>
                <th>Datum početka</th>
                <th>Datum završetka</th>
                <th>Status</th>
                <th>Smeštajna jedinica</th>
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.AranzmanRezervacije.Naziv</td>
                    <td>@r.AranzmanRezervacije.DatumPocetka</td>
                    <td>@r.AranzmanRezervacije.DatumZavrsetka</td>
                    <td>@r.Status</td>
                    <td>
                        Broj gostiju: @r.Jedinica.DozvoljenBrojGostiju <br />
                        Ljubimci: @(r.Jedinica.DozvoljeniLjubimci ? "Da" : "Ne") <br />
                        Cena: @r.Jedinica.Cena
                    </td>
                    <td>
                        @if (r.Status == RezervacijaStatus.Aktivna)
                        {
                            using (Html.BeginForm("Otkazi", "Turista", FormMethod.Post))
                            {
                                @Html.Hidden("id", r.Id)
                                <input type="submit" value="Otkaži" class="btn btn-danger btn-sm"
                                       onclick="return confirm('Da li ste sigurni da želite da otkažete ovu rezervaciju?');" />
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                        <a href="/Turista/Detalji?id=@r.Id" class="btn btn-primary btn-sm">Detalji</a>
                    </td> 

                </tr>
            }
        </tbody>
    </table>
}
